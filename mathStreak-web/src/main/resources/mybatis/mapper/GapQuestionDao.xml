<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lods.dao.GapQuestionDao">

    <resultMap id="GapQuestionMap" type="com.lods.domain.po.Question">
        <id column="id" property="questionId"/>
        <result column="question" property="description"/>
        <result column="answer" property="answer"/>
        <result column="diff" property="difficultyLevel"/>
        <result column="total_rows" property="total"/>

    </resultMap>

    <select id="getQuestions" resultMap="GapQuestionMap">
        select * from gap where id = #{ramId}
    </select>

    <select id="getTotal" resultMap="GapQuestionMap">
        select count(*) AS total_rows FROM gap;
    </select>
</mapper>
