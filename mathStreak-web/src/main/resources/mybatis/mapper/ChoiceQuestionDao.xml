<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lods.dao.ChoiceQuestionDao">

    <resultMap id="ChoiceQuestionMap" type="com.lods.domain.vo.ChoiceQuestionVO">
        <id column="id" property="questionId"/>
        <result column="question" property="description"/>
        <result column="opt_a" property="optA"/>
        <result column="opt_b" property="optB"/>
        <result column="opt_c" property="optC"/>
        <result column="opt_d" property="optD"/>
        <result column="answer" property="answer"/>
        <result column="diff" property="difficultyLevel"/>
        <result column="total_rows" property="total"/>

    </resultMap>

    <select id="getQuestions" resultMap="ChoiceQuestionMap">
        select * from choice where id = #{ramId}
    </select>

    <select id="getTotal" resultMap="ChoiceQuestionMap">
        select count(*) AS total_rows FROM choice;
    </select>
</mapper>
